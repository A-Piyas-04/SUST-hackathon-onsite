# Backend environment variables — copy to .env and fill in real values locally.
# NEVER commit a real .env file. No real credentials, ever (see docs/schema.md and System-Design.md guardrails).

# --- Database (Postgres) ---
# For local dev, this matches docker-compose.yml's local Postgres service.
# For Supabase later, swap in the pooled connection string from
# Supabase Project Settings -> Database -> Connection string (Transaction pooler),
# using the async driver prefix: postgresql+asyncpg://...
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/liquidity_platform

# Sync driver variant used only by migrations/run_migrations.py (psycopg2).
# Keep this in sync with DATABASE_URL above (same host/db, different driver prefix).
MIGRATIONS_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/liquidity_platform

# --- Supabase (optional, wired for later phases; not required for local Postgres dev) ---
# Project URL, e.g. https://xxxxxxxxxxxx.supabase.co
SUPABASE_URL=
# Anon/public key — safe for client-side use, still never commit a real value here.
SUPABASE_ANON_KEY=
# Service role key — backend/service-only, must never be exposed to a frontend.
SUPABASE_SERVICE_ROLE_KEY=

# --- App ---
ENV=local
LOG_LEVEL=INFO
