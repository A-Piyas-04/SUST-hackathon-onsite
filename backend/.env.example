# --- Supabase project API -----------------------------------------------------
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# --- PostgreSQL connections ----------------------------------------------------
# Pooler / session connection for normal application access where appropriate.
DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@YOUR_POOLER_HOST:5432/postgres?sslmode=require

# Direct PostgreSQL connection, preferred for migrations and RLS session tests.
# The migration runner uses DIRECT_DATABASE_URL first and falls back to
# DATABASE_URL when the direct connection is unavailable on this network.
DIRECT_DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres?sslmode=require

# --- Supabase CLI / project metadata ------------------------------------------
SUPABASE_PROJECT_REF=YOUR_PROJECT_REF
SUPABASE_DB_PASSWORD=YOUR_DATABASE_PASSWORD

# --- Runner controls ----------------------------------------------------------
# APP_ENV must equal `development` (or `local`) for the destructive `reset`
# command to run. Any other value makes `reset` refuse to drop objects.
APP_ENV=development

# --- Application (Phase 2) ----------------------------------------------------
APP_NAME=liquidity-platform
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
DEMO_AUTH_ENABLED=true
FEATURE_INTERNAL_ANALYTICS_STUBS=false
CONTRACT_VERSION=1.0.0

# -----------------------------------------------------------------------------
# Local-only development example (plain Postgres, no Supabase). To verify the
# migration chain without Supabase credentials, point DIRECT_DATABASE_URL at a
# local server and leave the Supabase values as placeholders, e.g.:
#   DIRECT_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/liquidity_platform
# The migrations create guarded `auth.users` and role shims so the chain also
# applies on a plain PostgreSQL instance (see docs/adr/0002 and docs/adr/0004).
# -----------------------------------------------------------------------------
